{
  "manifest_version": 3,
  "name": "Wiki Map",
  "description": "Visualize Wikipedia page jumps as a mind map.",
  "version": "1.0.0",
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Wiki Map",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.wikipedia.org/wiki/*"
      ],
      "exclude_matches": [
        "https://*.wikipedia.org/wiki/Special:*"
      ],
      "css": [
        "sidebar.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
